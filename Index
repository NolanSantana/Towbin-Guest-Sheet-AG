<script>
const PDF = {
  PW:612, PH:792, ML:44, MR:44, MT:44, MB:44,
  CW_MAP:{"a":556,"b":556,"c":500,"d":556,"e":556,"f":278,"g":556,"h":556,"i":222,"j":222,"k":500,"l":222,"m":833,"n":556,"o":556,"p":556,"q":556,"r":333,"s":500,"t":278,"u":556,"v":500,"w":722,"x":500,"y":500,"z":500,"A":667,"B":667,"C":722,"D":722,"E":667,"F":611,"G":778,"H":722,"I":278,"J":500,"K":667,"L":611,"M":833,"N":722,"O":778,"P":667,"Q":778,"R":722,"S":667,"T":611,"U":722,"V":667,"W":944,"X":667,"Y":667,"Z":611,"0":556,"1":556,"2":556,"3":556,"4":556,"5":556,"6":556,"7":556,"8":556,"9":556," ":278,".":278,",":278,":":278,";":278,"!":278,"?":556,"-":333,"$":556,"(":333,")":333,"/":278,"&":667,"@":1015,"#":556,"'":222},
  tw(s,sz,bold){return[...String(s)].reduce((a,c)=>a+(this.CW_MAP[c]||500),0)/1000*sz*(bold?1.08:1);},
  wrap(s,maxW,sz,bold){const words=String(s).split(' ');const lines=[];let cur='';for(const w of words){const t=cur?cur+' '+w:w;if(this.tw(t,sz,bold)<=maxW){cur=t;}else{if(cur)lines.push(cur);cur=w;}}if(cur)lines.push(cur);return lines.length?lines:[''];},
  esc(s){return String(s||'').replace(/\\/g,'\\\\').replace(/\(/g,'\\(').replace(/\)/g,'\\)').replace(/\r?\n/g,' ');},

  generate(data) {
    const pages=[];let ops=[];
    const PW=this.PW,PH=this.PH,ML=this.ML,MR=this.MR,MB=this.MB,MT=this.MT;
    const CW=PW-ML-MR;
    let y=PH-MT;
    const me=this;

    const RED   ='0.733 0.039 0.118';
    const INK   ='0.059 0.059 0.059';
    const MID   ='0.353 0.353 0.353';
    const MUTED ='0.600 0.600 0.600';
    const BGROW ='0.976 0.969 0.957';
    const WHITE ='1.000 1.000 1.000';
    const REDLT ='0.992 0.941 0.945';
    const RULE  ='0.878 0.867 0.847';

    function newPage(){if(ops.length)pages.push([...ops]);ops=[];y=PH-MT;}
    function need(h){if(y-h<MB+10){newPage();return true;}return false;}
    function rect(x,yr,w,h,c){ops.push(`${c} rg`);ops.push(`${x.toFixed(1)} ${yr.toFixed(1)} ${w.toFixed(1)} ${h.toFixed(1)} re f`);}
    function hline(x1,yr,x2,lw,c){ops.push(`${c} RG`);ops.push(`${lw} w`);ops.push(`${x1.toFixed(1)} ${yr.toFixed(1)} m ${x2.toFixed(1)} ${yr.toFixed(1)} l S`);}
    function txt(x,yr,s,f,sz,c){ops.push(`${c} rg`);ops.push(`BT /${f} ${sz} Tf ${x.toFixed(1)} ${yr.toFixed(1)} Td (${me.esc(s)}) Tj ET`);}
    function txtR(x,yr,s,f,sz,c){txt(x-me.tw(s,sz,f==='F2'),yr,s,f,sz,c);}
    function txtC(cx,yr,s,f,sz,c){txt(cx-me.tw(s,sz,f==='F2')/2,yr,s,f,sz,c);}

    const d=data;
    const dateStr=new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
    const guestName=[d.fname,d.lname].filter(Boolean).join(' ')||'Guest';
    const spName=d.sp_name||'—';
    const spNotes=d.sp_notes||'—';

    // ── RED TOP BAR ──
    rect(0,PH-6,PW,6,RED);
    y=PH-6-20;

    // ── TOWBIN LOGO (vector) ──
    // Badge background - rounded rectangle silver/dark
    const bx=ML, by=PH-6-52, bw=180, bh=46;
    // Outer badge dark border
    ops.push(`0.200 0.200 0.200 rg`);
    ops.push(`${bx.toFixed(1)} ${by.toFixed(1)} ${bw.toFixed(1)} ${bh.toFixed(1)} re f`);
    // Inner badge silver fill
    ops.push(`0.720 0.720 0.730 rg`);
    ops.push(`${(bx+3).toFixed(1)} ${(by+3).toFixed(1)} ${(bw-6).toFixed(1)} ${(bh-6).toFixed(1)} re f`);
    // Badge highlight top strip
    ops.push(`0.850 0.850 0.860 rg`);
    ops.push(`${(bx+3).toFixed(1)} ${(by+bh-12).toFixed(1)} ${(bw-6).toFixed(1)} ${(9).toFixed(1)} re f`);
    // TOWBIN text
    ops.push(`0.100 0.100 0.120 rg`);
    ops.push(`BT /F2 17 Tf ${(bx+14).toFixed(1)} ${(by+bh-26).toFixed(1)} Td (TOWBIN) Tj ET`);
    // AUTO GROUP text
    ops.push(`0.150 0.150 0.180 rg`);
    ops.push(`BT /F1 7 Tf ${(bx+28).toFixed(1)} ${(by+10).toFixed(1)} Td (\u00B7AUTO GROUP\u00B7) Tj ET`);
    // Dot accents left and right of AUTO GROUP
    y = PH-6-14;
    txt(ML+185, y, 'GUEST SHEET','F2',11,RED);

    // Right meta
    let my=PH-6-20;
    for(const [l,v] of [['Date:',dateStr],['Salesperson:',spName],['Guest:',guestName]]){
      txtR(PW-MR,my,`${l}  ${v}`,'F1',8.5,MID);
      my-=12;
    }

    y=PH-6-58;
    hline(ML,y,PW-MR,1.5,INK);
    y-=14;

    const LW=CW*0.36, VW=CW*0.64;

    function section(title,rows){
      const valid=rows.filter(([,v])=>v);
      if(!valid.length)return;
      const est=14+valid.reduce((a,[,v])=>a+me.wrap(v,VW-10,11).length*13+6,0);
      need(est);
      rect(ML,y-10,CW,14,INK);
      txt(ML+7,y-7,title.toUpperCase(),'F2',7.5,WHITE);
      y-=17;
      valid.forEach(([label,val],i)=>{
        const wrapped=me.wrap(val,VW-10,11);
        const rh=Math.max(17,wrapped.length*13+5);
        need(rh+2);
        rect(ML,y-rh+4,CW,rh,i%2===0?WHITE:BGROW);
        txt(ML+6,y-3,label.toUpperCase(),'F1',7.5,MUTED);
        wrapped.forEach((line,li)=>txt(ML+LW,y-3-li*13,line,'F1',11,INK));
        hline(ML,y-rh+4,ML+CW,0.4,RULE);
        y-=rh;
      });
      y-=12;
    }

    function gv(k){const v=d[k];return Array.isArray(v)&&v.length?v[0]:(v||null);}
    function jv(k){const v=d[k];return Array.isArray(v)&&v.length?v.join(', '):null;}

    section('Contact Information',[
      ['Name',guestName],
      ['Address',d.address],
      ['Home Phone',d.home_phone],
      ['Cell / Work',d.cell_phone],
      ['Email',d.email],
      ['How They Heard',jv('source')],
    ]);

    section('Vehicle of Interest',[
      ['New or Pre-Owned',gv('new_used')],
      ['Year / Make / Model',[d.veh_year,d.veh_make,d.veh_model].filter(Boolean).join(' ')||null],
      ['Stock #',d.stock_num],
      ['Color Preference',d.veh_color],
      ['Down Payment',d.down?'$'+d.down:null],
      ['Needs / Wants',d.needs],
    ]);

    section('Trade-In Information',[
      ['Has Trade-In',gv('has_trade')],
      ['Year / Make / Model',[d.t_year,d.t_make,d.t_model].filter(Boolean).join(' ')||null],
      ['Mileage',d.t_miles],
      ['Current Payment',d.t_payment?'$'+d.t_payment:null],
      ['Current Payoff',d.t_payoff?'$'+d.t_payoff:null],
      ['Lender',d.t_lender],
    ]);

    section('Credit Information',[
      ['Score Estimate',gv('credit_grade')],
      ['Do Business Now',gv('do_business')],
    ]);

    // Salesperson notes box
    const spWrapped=me.wrap(spNotes,CW-24,11);
    const spH=14+13+spWrapped.length*13+18;
    need(spH+10);
    rect(ML,y-spH+8,CW,spH,REDLT);
    rect(ML,y-spH+8,4,spH,RED);
    txt(ML+12,y-2,'SALESPERSON NOTES','F2',7.5,RED);
    txt(ML+12,y-13,`Written by: ${spName}`,'F1',8,MUTED);
    spWrapped.forEach((line,i)=>txt(ML+12,y-24-i*13,line,'F1',11,INK));
    y-=spH+10;

    // Signature line
    need(50);
    hline(ML,y,ML+180,1,INK);
    txt(ML,y-10,'X  Guest Signature','F1',8,MUTED);
    txtR(PW-MR,y,'Date:  _______________','F1',8,MUTED);
    y-=28;

    // Tagline + Yes/No checkboxes
    need(50);
    txtC(PW/2,y,'IF ALL TERMS ARE AGREEABLE, WE CAN EARN YOUR BUSINESS NOW.','F2',9,INK);
    y-=22;

    const answer = (d.do_business && d.do_business[0]) || '';
    const cbSize = 13;
    const cbY = y;

    // YES checkbox
    ops.push(`0.200 0.200 0.200 RG`); ops.push(`0.8 w`);
    ops.push(`${(PW/2-80).toFixed(1)} ${(cbY-cbSize+2).toFixed(1)} ${cbSize} ${cbSize} re S`);
    if(answer === 'Yes'){
      ops.push(`0.733 0.039 0.118 rg`);
      ops.push(`${(PW/2-80).toFixed(1)} ${(cbY-cbSize+2).toFixed(1)} ${cbSize} ${cbSize} re f`);
      ops.push(`1 1 1 rg`);
      ops.push(`BT /F2 10 Tf ${(PW/2-77).toFixed(1)} ${(cbY-cbSize+5).toFixed(1)} Td (X) Tj ET`);
    }
    txt(PW/2-62, cbY-cbSize+8, 'YES', 'F2', 9, answer==='Yes' ? RED : INK);

    // NO checkbox
    ops.push(`0.200 0.200 0.200 RG`); ops.push(`0.8 w`);
    ops.push(`${(PW/2+20).toFixed(1)} ${(cbY-cbSize+2).toFixed(1)} ${cbSize} ${cbSize} re S`);
    if(answer === 'No'){
      ops.push(`0.733 0.039 0.118 rg`);
      ops.push(`${(PW/2+20).toFixed(1)} ${(cbY-cbSize+2).toFixed(1)} ${cbSize} ${cbSize} re f`);
      ops.push(`1 1 1 rg`);
      ops.push(`BT /F2 10 Tf ${(PW/2+23).toFixed(1)} ${(cbY-cbSize+5).toFixed(1)} Td (X) Tj ET`);
    }
    txt(PW/2+38, cbY-cbSize+8, 'NO', 'F2', 9, answer==='No' ? RED : INK);

    y-=24;

    hline(ML,y,PW-MR,0.5,RULE);
    y-=10;
    const ft=`Confidential \u2014 Towbin Auto Group \u00B7 Generated ${dateStr}`;
    txtC(PW/2,y,ft,'F1',7,MUTED);

    pages.push([...ops]);
    return this._buildPDF(pages);
  },

  _buildPDF(pages){
    const enc=s=>[...s].map(c=>c.charCodeAt(0));
    const chunks=[];const offsets={};
    function emit(s){chunks.push(enc(s));}
    function bytes(){return chunks.reduce((a,b)=>a+b.length,0);}
    const nP=pages.length;
    const pageObjs=Array.from({length:nP},(_,i)=>5+i*2+1);
    emit('%PDF-1.4\n%\xFF\xFF\xFF\xFF\n');
    offsets[1]=bytes();emit(`1 0 obj\n<< /Type /Catalog /Pages 2 0 R >>\nendobj\n`);
    offsets[2]=bytes();emit(`2 0 obj\n<< /Type /Pages /Kids [${pageObjs.map(n=>`${n} 0 R`).join(' ')}] /Count ${nP} >>\nendobj\n`);
    offsets[3]=bytes();emit(`3 0 obj\n<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>\nendobj\n`);
    offsets[4]=bytes();emit(`4 0 obj\n<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold /Encoding /WinAnsiEncoding >>\nendobj\n`);
    for(let i=0;i<nP;i++){
      const cObj=5+i*2, pObj=5+i*2+1;
      const stream=pages[i].join('\n')+'\n';
      offsets[cObj]=bytes();emit(`${cObj} 0 obj\n<< /Length ${stream.length} >>\nstream\n${stream}endstream\nendobj\n`);
      offsets[pObj]=bytes();emit(`${pObj} 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${this.PW} ${this.PH}] /Contents ${cObj} 0 R /Resources << /Font << /F1 3 0 R /F2 4 0 R >> >> >>\nendobj\n`);
    }
    const xOff=bytes();const total=4+nP*2;
    emit(`xref\n0 ${total+1}\n`);emit(`0000000000 65535 f \n`);
    for(let i=1;i<=total;i++)emit(`${String(offsets[i]||0).padStart(10,'0')} 00000 n \n`);
    emit(`trailer\n<< /Size ${total+1} /Root 1 0 R >>\nstartxref\n${xOff}\n%%EOF\n`);
    return new Uint8Array(chunks.flat());
  }
};

/* ══ FORM LOGIC ══ */
const TOTAL = 4;
let current = 1;
const fd = {};
const pillData = {};

function startForm() {
  document.getElementById('landing').style.display = 'none';
  document.getElementById('form-screen').style.display = 'block';
}

function updateProgress() {
  document.getElementById('step-num').textContent = current;
  document.getElementById('progress-fill').style.width = (current / TOTAL * 100) + '%';
  document.getElementById('btn-back').style.display = current > 1 ? 'block' : 'none';
  const nb = document.getElementById('btn-next');
  if (current === TOTAL) {
    nb.textContent = '✓  Submit';
    nb.className = 'btn btn-submit';
  } else {
    nb.textContent = 'Continue →';
    nb.className = 'btn btn-next';
  }
}

function showStep(n) {
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  const p = document.getElementById('step-' + n);
  if (p) p.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  updateProgress();
}

function v(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }

function collect() {
  if (current === 1) {
    fd.fname      = v('fname');
    fd.lname      = v('lname');
    fd.address    = v('address');
    fd.home_phone = v('home-phone');
    fd.cell_phone = v('cell-phone');
    fd.email      = v('email');
  }
  if (current === 2) {
    fd.stock_num  = v('stock-num');
    fd.veh_color  = v('veh-color');
    fd.down       = v('down');
    fd.needs      = v('needs');
  }
  if (current === 3) {
    fd.t_year     = v('t-year');
    fd.t_make     = v('t-make');
    fd.t_model    = v('t-model');
    fd.t_miles    = v('t-miles');
    fd.t_payment  = v('t-payment');
    fd.t_payoff   = v('t-payoff');
    fd.t_lender   = v('t-lender');
  }
  Object.assign(fd, pillData);
}

function nextStep() { collect(); if (current < TOTAL) { current++; showStep(current); } else submitForm(); }
function prevStep() { if (current > 1) { current--; showStep(current); } }

function submitForm() {
  collect();
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('topbar').style.display = 'none';
  document.getElementById('bottom-nav').style.display = 'none';
  document.getElementById('success-screen').classList.add('show');
  buildSummary();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function buildSummary() {
  const d = fd;
  const secs = [
    { t: 'Contact', rows: [['Name', [d.fname, d.lname].filter(Boolean).join(' ')], ['Phone', d.cell_phone || d.home_phone], ['Email', d.email], ['Source', d.source?.join(', ')]] },
    { t: 'Vehicle of Interest', rows: [['New/Used', d.new_used?.[0]], ['Stock #', d.stock_num], ['Down', d.down ? '$' + d.down : null], ['Needs/Wants', d.needs]] },
    { t: 'Trade-In', rows: [['Has Trade', d.has_trade?.[0]], ['Trade Vehicle', [d.t_year, d.t_make, d.t_model].filter(Boolean).join(' ')], ['Current Payment', d.t_payment ? '$' + d.t_payment : null], ['Current Payoff', d.t_payoff ? '$' + d.t_payoff : null], ['Lender', d.t_lender]] },
    { t: 'Credit', rows: [['Score', d.credit_grade?.[0]], ['Do Business Now', d.do_business?.[0]]] },
  ];
  let html = '';
  secs.forEach(s => {
    const valid = s.rows.filter(([, v]) => v);
    if (!valid.length) return;
    html += `<div class="sum-sec">${s.t}</div>`;
    valid.forEach(([l, v]) => { html += `<div class="sum-row"><span class="s-label">${l}</span><span class="s-val">${v}</span></div>`; });
  });
  document.getElementById('summary-card').innerHTML = html;
}

function savePDF() {
  const btn = document.getElementById('pdf-btn');
  const status = document.getElementById('pdf-status');
  btn.classList.add('loading');
  btn.textContent = '⏳  Building PDF…';
  status.textContent = '';
  setTimeout(() => {
    try {
      const payload = {
        ...fd, ...pillData,
        sp_name:  document.getElementById('sp-name').value.trim(),
        sp_notes: document.getElementById('sp-notes').value.trim(),
      };
      const pdfBytes = PDF.generate(payload);
      const blob = new Blob([pdfBytes], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const name = [fd.fname, fd.lname].filter(Boolean).join('_') || 'Guest';
      const date = new Date().toISOString().slice(0, 10);
      a.href = url;
      a.download = `TowbinAutoGroup_GuestSheet_${name}_${date}.pdf`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 5000);
      btn.classList.remove('loading');
      btn.textContent = '✓  PDF Saved!';
      status.textContent = 'Check your Downloads or Files app.';
      setTimeout(() => { btn.textContent = '📄  Save Guest Sheet as PDF'; status.textContent = ''; }, 5000);
    } catch (e) {
      btn.classList.remove('loading');
      btn.textContent = '📄  Save Guest Sheet as PDF';
      status.textContent = '⚠  Something went wrong. Please try again.';
      console.error(e);
    }
  }, 60);
}

/* ══ PILL LOGIC ══ */
document.querySelectorAll('.pill-btn[data-group]').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.dataset.group;
    const isSingle = btn.dataset.single === 'true';
    if (isSingle) {
      document.querySelectorAll(`.pill-btn[data-group="${group}"]`).forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      if (group === 'has_trade') {
        const tf = document.getElementById('trade-fields');
        btn.dataset.val === 'Yes' ? tf.classList.add('show') : tf.classList.remove('show');
      }
    } else {
      btn.classList.toggle('selected');
    }
    pillData[group] = [...document.querySelectorAll(`.pill-btn[data-group="${group}"].selected`)].map(b => b.dataset.val);
  });
});

/* Credit scale */
document.querySelectorAll('.credit-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.credit-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    pillData.credit_grade = [btn.dataset.val];
  });
});

updateProgress();
</script>
</body>
</html>
