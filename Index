<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Towbin Auto Group — Guest Sheet</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --red:       #C8102E;
  --red-dark:  #9e0b23;
  --red-light: #fff0f2;
  --ink:       #111111;
  --ink-mid:   #444444;
  --muted:     #888888;
  --rule:      #e2e2e2;
  --bg:        #f5f5f5;
  --card:      #ffffff;
  --radius:    12px;
  --font-body: 'Inter', sans-serif;
  --font-display: 'Bebas Neue', sans-serif;
}

html, body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--ink);
  min-height: 100vh;
  -webkit-tap-highlight-color: transparent;
  -webkit-font-smoothing: antialiased;
}

/* ═══ LANDING ═══ */
#landing {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48px 24px 60px;
  background: var(--ink);
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* Subtle grid overlay */
#landing::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

/* Red accent bar at top */
#landing::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
  background: var(--red);
}

.landing-logo-wrap {
  position: relative;
  z-index: 1;
  margin-bottom: 32px;
}

.landing-logo {
  width: 240px;
  max-width: 72vw;
  border-radius: 10px;
  display: block;
  margin: 0 auto;
  filter: brightness(1.05) contrast(1.05);
}

.landing-eyebrow {
  font-family: var(--font-display);
  font-size: 11px;
  letter-spacing: 4px;
  color: var(--red);
  text-transform: uppercase;
  margin-bottom: 10px;
  position: relative;
  z-index: 1;
}

.landing-title {
  font-family: var(--font-display);
  font-size: 54px;
  line-height: 1;
  letter-spacing: 3px;
  color: #fff;
  margin-bottom: 6px;
  position: relative;
  z-index: 1;
}

.landing-sub {
  font-size: 12px;
  color: rgba(255,255,255,.4);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 44px;
  position: relative;
  z-index: 1;
}

.btn-start {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 18px 40px;
  background: var(--red);
  color: white;
  border: none;
  border-radius: var(--radius);
  font-family: var(--font-display);
  font-size: 20px;
  letter-spacing: 2px;
  cursor: pointer;
  transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 24px rgba(200,16,46,.5);
}
.btn-start:active { transform: scale(0.97); background: var(--red-dark); }

.landing-disclaimer {
  position: relative;
  z-index: 1;
  margin-top: 28px;
  font-size: 11px;
  color: rgba(255,255,255,.25);
  line-height: 1.6;
  max-width: 320px;
}

/* ═══ FORM SCREEN ═══ */
#form-screen { display: none; }

/* TOP BAR */
.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--card);
  border-bottom: 1px solid var(--rule);
  padding: 0 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
}

.topbar-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0 10px;
}

.brand-name {
  font-family: var(--font-display);
  font-size: 16px;
  letter-spacing: 2px;
  color: var(--ink);
}

.brand-sub {
  font-size: 9px;
  color: var(--muted);
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-top: 2px;
}

.step-counter {
  text-align: right;
  font-size: 11px;
  color: var(--muted);
  letter-spacing: .5px;
}
.step-counter strong {
  display: block;
  font-family: var(--font-display);
  font-size: 28px;
  line-height: 1;
  color: var(--ink);
  letter-spacing: 0;
}

.progress-track {
  height: 3px;
  background: var(--rule);
  margin: 0 -20px;
}
.progress-fill {
  height: 100%;
  background: var(--red);
  transition: width 0.45s cubic-bezier(.4,0,.2,1);
}

/* MAIN FORM AREA */
.main {
  padding: 28px 20px 120px;
  max-width: 540px;
  margin: 0 auto;
}

.step-panel { display: none; }
.step-panel.active {
  display: block;
  animation: slideUp .28s ease;
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

.step-eyebrow {
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--red);
  font-weight: 700;
  margin-bottom: 6px;
}

.step-heading {
  font-family: var(--font-display);
  font-size: 32px;
  letter-spacing: 1.5px;
  line-height: 1.1;
  margin-bottom: 4px;
  color: var(--ink);
}

.step-desc {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 26px;
  line-height: 1.5;
}

/* ── FIELDS ── */
.field { margin-bottom: 16px; }

.field-label {
  display: block;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  font-weight: 700;
  color: var(--muted);
  margin-bottom: 7px;
}

.field input[type="text"],
.field input[type="tel"],
.field input[type="email"],
.field input[type="number"],
.field textarea {
  width: 100%;
  background: var(--card);
  border: 1.5px solid var(--rule);
  border-radius: 10px;
  padding: 13px 15px;
  font-size: 16px;
  font-family: var(--font-body);
  color: var(--ink);
  outline: none;
  transition: border-color .18s, box-shadow .18s;
  -webkit-appearance: none;
}

.field input:focus,
.field textarea:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(200,16,46,.12);
}

.field textarea { resize: none; line-height: 1.5; }

.field-row   { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }

/* ── PILLS ── */
.pill-group { display: flex; flex-wrap: wrap; gap: 8px; }

.pill-btn {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 12px 15px;
  border: 1.5px solid var(--rule);
  border-radius: 10px;
  background: var(--card);
  font-size: 14px;
  font-family: var(--font-body);
  font-weight: 500;
  color: var(--ink);
  cursor: pointer;
  transition: all .15s;
  user-select: none;
  flex: 1 1 calc(50% - 4px);
  text-align: left;
}
.pill-btn.wide { flex: 1 1 100%; }
.pill-btn.auto { flex: 0 0 auto; }

.pill-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 2px solid var(--rule);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all .15s;
}
.pill-btn.check .pill-icon { border-radius: 4px; }

.pill-btn.selected {
  border-color: var(--red);
  background: var(--red-light);
  color: var(--red);
}
.pill-btn.selected .pill-icon {
  background: var(--red);
  border-color: var(--red);
}
.pill-btn.selected .pill-icon::after {
  content: '✓';
  font-size: 10px;
  color: white;
  font-weight: bold;
}
.pill-btn:active { transform: scale(0.97); }
.pill-label { flex: 1; line-height: 1.3; }

/* ── CREDIT SCALE ── */
.credit-scale {
  display: grid;
  grid-template-columns: repeat(6,1fr);
  gap: 7px;
}

.credit-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 12px 4px;
  border: 1.5px solid var(--rule);
  border-radius: 10px;
  background: var(--card);
  cursor: pointer;
  transition: all .15s;
  font-family: var(--font-body);
}
.credit-btn .grade {
  font-family: var(--font-display);
  font-size: 22px;
  letter-spacing: 1px;
  color: var(--ink);
}
.credit-btn .score { font-size: 9px; color: var(--muted); font-weight: 500; }
.credit-btn.selected { border-color: var(--red); background: var(--red-light); }
.credit-btn.selected .grade { color: var(--red); }
.credit-btn:active { transform: scale(0.96); }

/* ── TRADE REVEAL ── */
.trade-reveal { display: none; animation: slideUp .25s ease; }
.trade-reveal.show { display: block; }

/* ── CARD ── */
.card {
  background: var(--card);
  border: 1.5px solid var(--rule);
  border-radius: var(--radius);
  padding: 18px;
  margin-bottom: 16px;
}
.card-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--rule);
}

/* ── CONSENT ── */
.consent-box {
  padding: 14px 16px;
  background: var(--red-light);
  border-radius: 10px;
  border-left: 3px solid var(--red);
  margin-top: 6px;
}
.consent-box p {
  font-size: 11px;
  color: var(--ink-mid);
  line-height: 1.65;
}

/* ── DO BUSINESS BOX ── */
.do-business-box {
  margin-top: 24px;
  margin-bottom: 20px;
  background: var(--card);
  border: 2px solid var(--ink);
  border-radius: var(--radius);
  padding: 20px;
}
.do-business-box p {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  text-align: center;
  margin-bottom: 16px;
  color: var(--ink);
  line-height: 1.5;
}
.do-business-btns {
  display: flex;
  gap: 12px;
}
.do-business-btns .pill-btn {
  flex: 1;
  justify-content: center;
  font-size: 15px;
  font-weight: 700;
  padding: 14px;
}

/* ── BOTTOM NAV ── */
.bottom-nav {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: var(--card);
  border-top: 1px solid var(--rule);
  padding: 14px 20px calc(14px + env(safe-area-inset-bottom));
  display: flex;
  gap: 10px;
  max-width: 540px;
  margin: 0 auto;
  box-shadow: 0 -4px 20px rgba(0,0,0,.08);
}
@media (min-width: 540px) {
  .bottom-nav { left: 50%; transform: translateX(-50%); width: 540px; }
}

.btn {
  flex: 1;
  padding: 16px;
  border-radius: 11px;
  font-size: 15px;
  font-family: var(--font-body);
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all .15s;
  letter-spacing: .3px;
}
.btn-back {
  background: var(--bg);
  color: var(--muted);
  border: 1.5px solid var(--rule);
  flex: 0 0 80px;
}
.btn-next {
  background: var(--ink);
  color: white;
}
.btn-submit {
  background: var(--red);
  color: white;
  box-shadow: 0 4px 16px rgba(200,16,46,.35);
}
.btn:active { transform: scale(0.97); }

/* ── SUCCESS SCREEN ── */
.success-screen {
  display: none;
  text-align: center;
  padding: 48px 20px 60px;
  animation: slideUp .4s ease;
}
.success-screen.show { display: block; }

.success-icon {
  width: 72px;
  height: 72px;
  background: var(--red);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  margin: 0 auto 20px;
  color: white;
  box-shadow: 0 8px 24px rgba(200,16,46,.35);
}

.success-screen h2 {
  font-family: var(--font-display);
  font-size: 38px;
  letter-spacing: 2px;
  margin-bottom: 8px;
}

.success-screen > p {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.6;
  margin-bottom: 28px;
  max-width: 380px;
  margin-left: auto;
  margin-right: auto;
}

/* SUMMARY CARD */
.summary-card {
  background: var(--card);
  border: 1.5px solid var(--rule);
  border-radius: var(--radius);
  padding: 20px;
  margin: 0 auto 20px;
  max-width: 420px;
  text-align: left;
}

.sum-sec {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--red);
  margin: 14px 0 8px;
  padding-top: 14px;
  border-top: 1px solid var(--rule);
}
.sum-sec:first-child { margin-top: 0; padding-top: 0; border-top: none; }

.sum-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 6px 0;
  border-bottom: 1px solid var(--rule);
  font-size: 13px;
}
.sum-row:last-child { border-bottom: none; }
.s-label { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .8px; flex-shrink: 0; margin-right: 12px; font-weight: 600; }
.s-val { font-weight: 600; text-align: right; color: var(--ink); }

/* SALESPERSON CARD */
.sp-card {
  background: var(--red-light);
  border: 1.5px solid var(--red);
  border-radius: var(--radius);
  padding: 18px;
  margin: 0 auto 20px;
  max-width: 420px;
  text-align: left;
}
.sp-card .card-title { color: var(--red); border-color: rgba(200,16,46,.2); }
.sp-card input,
.sp-card textarea {
  width: 100%;
  background: var(--card);
  border: 1.5px solid var(--rule);
  border-radius: 10px;
  padding: 12px 14px;
  font-size: 15px;
  font-family: var(--font-body);
  color: var(--ink);
  outline: none;
  margin-bottom: 12px;
  -webkit-appearance: none;
  transition: border-color .18s, box-shadow .18s;
}
.sp-card input:focus,
.sp-card textarea:focus {
  border-color: var(--red);
  box-shadow: 0 0 0 3px rgba(200,16,46,.12);
}
.sp-card textarea { resize: none; }
.sp-card .field-label {
  display: block;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--muted);
  font-weight: 700;
  margin-bottom: 7px;
}

/* ACTION BTNS */
.action-btns { display: flex; flex-direction: column; gap: 10px; max-width: 420px; margin: 0 auto; }

.btn-pdf {
  width: 100%;
  padding: 18px;
  border-radius: 11px;
  font-size: 15px;
  font-weight: 700;
  font-family: var(--font-body);
  border: none;
  cursor: pointer;
  background: var(--ink);
  color: white;
  transition: all .15s;
  letter-spacing: .3px;
}
.btn-pdf:active { transform: scale(0.98); }
.btn-pdf.loading { opacity: .6; pointer-events: none; }

.btn-new {
  width: 100%;
  padding: 14px;
  border-radius: 11px;
  font-size: 14px;
  font-family: var(--font-body);
  font-weight: 500;
  color: var(--muted);
  background: transparent;
  border: 1.5px solid var(--rule);
  cursor: pointer;
  transition: all .15s;
}
.btn-new:active { background: var(--bg); }

.pdf-status {
  font-size: 12px;
  color: var(--muted);
  text-align: center;
  min-height: 18px;
  margin-top: 2px;
}

/* CREDIT HELPER TEXT */
.credit-helper {
  font-size: 11px;
  color: var(--muted);
  margin-bottom: 12px;
  line-height: 1.55;
  padding: 10px 13px;
  background: var(--card);
  border-radius: 8px;
  border: 1px solid var(--rule);
}
.credit-helper strong { color: var(--ink); }
</style>
</head>
<body>

<!-- ══ LANDING ══ -->
<div id="landing">
  <div class="landing-logo-wrap">
    <img src="data:image/jpeg;base64," alt="Towbin Auto Group" class="landing-logo">
  </div>
  <div class="landing-eyebrow">Henderson, NV</div>
  <div class="landing-title">Guest Sheet</div>
  <div class="landing-sub">New &amp; Pre-Owned Vehicles</div>
  <button class="btn-start" onclick="startForm()">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    Begin Guest Sheet
  </button>
  <p class="landing-disclaimer">Your information is kept strictly confidential and will never be sold or shared.</p>
</div>

<!-- ══ FORM ══ -->
<div id="form-screen">
  <div class="topbar" id="topbar">
    <div class="topbar-inner">
      <div class="brand">
        <div class="brand-name">Towbin Auto Group</div>
        <div class="brand-sub">Guest Information</div>
      </div>
      <div class="step-counter">
        <strong id="step-num">1</strong>
        <span>of 4</span>
      </div>
    </div>
    <div class="progress-track">
      <div class="progress-fill" id="progress-fill" style="width:25%"></div>
    </div>
  </div>

  <div class="main">

    <!-- STEP 1: CONTACT -->
    <div class="step-panel active" id="step-1">
      <div class="step-eyebrow">Step 1 of 4</div>
      <h2 class="step-heading">Contact Info</h2>
      <p class="step-desc">Let's start with your basic information.</p>

      <div class="field-row">
        <div class="field"><label class="field-label">First Name</label><input type="text" id="fname" placeholder="Jane" autocomplete="given-name"></div>
        <div class="field"><label class="field-label">Last Name</label><input type="text" id="lname" placeholder="Smith" autocomplete="family-name"></div>
      </div>
      <div class="field"><label class="field-label">Address</label><input type="text" id="address" placeholder="123 Main St, Henderson, NV 89002" autocomplete="street-address"></div>
      <div class="field-row">
        <div class="field"><label class="field-label">Home Phone</label><input type="tel" id="home-phone" placeholder="(702) 000-0000"></div>
        <div class="field"><label class="field-label">Cell / Work</label><input type="tel" id="cell-phone" placeholder="(702) 000-0000" autocomplete="tel"></div>
      </div>
      <div class="field"><label class="field-label">Email Address</label><input type="email" id="email" placeholder="jane@email.com" autocomplete="email"></div>
    </div>

    <!-- STEP 2: VEHICLE OF INTEREST -->
    <div class="step-panel" id="step-2">
      <div class="step-eyebrow">Step 2 of 4</div>
      <h2 class="step-heading">Vehicle of Interest</h2>
      <p class="step-desc">Tell us about the vehicle you're looking for.</p>

      <div class="field">
        <label class="field-label">New or Pre-Owned?</label>
        <div class="pill-group">
          <button class="pill-btn" data-group="new_used" data-single="true" data-val="New"><span class="pill-icon"></span><span class="pill-label">New</span></button>
          <button class="pill-btn" data-group="new_used" data-single="true" data-val="Pre-Owned"><span class="pill-icon"></span><span class="pill-label">Pre-Owned</span></button>
          <button class="pill-btn" data-group="new_used" data-single="true" data-val="Open"><span class="pill-icon"></span><span class="pill-label">Open</span></button>
        </div>
      </div>

      <div class="field-row">
        <div class="field"><label class="field-label">Stock # (if known)</label><input type="text" id="stock-num" placeholder="Optional"></div>
        <div class="field"><label class="field-label">Color Preference</label><input type="text" id="veh-color" placeholder="White, Black…"></div>
      </div>

      <div class="field">
        <label class="field-label">Down Payment</label>
        <input type="text" id="down" placeholder="$0" inputmode="numeric">
      </div>

      <div class="field">
        <label class="field-label">Needs / Wants</label>
        <textarea id="needs" rows="4" placeholder="e.g. 3rd row seating, towing package, great fuel economy, AWD…"></textarea>
      </div>
    </div>

    <!-- STEP 3: TRADE-IN -->
    <div class="step-panel" id="step-3">
      <div class="step-eyebrow">Step 3 of 4</div>
      <h2 class="step-heading">Trade&#8209;In</h2>
      <p class="step-desc">Do you have a vehicle to trade in today?</p>

      <div class="field">
        <div class="pill-group">
          <button class="pill-btn wide" data-group="has_trade" data-single="true" data-val="Yes" id="trade-yes-btn">
            <span class="pill-icon"></span><span class="pill-label">Yes, I have a trade-in</span>
          </button>
          <button class="pill-btn" data-group="has_trade" data-single="true" data-val="No">
            <span class="pill-icon"></span><span class="pill-label">No trade-in</span>
          </button>
        </div>
      </div>

      <div class="trade-reveal" id="trade-fields">
        <div class="card">
          <div class="card-title">Trade-In Details</div>
          <div class="field-row-3" style="margin-bottom:14px;">
